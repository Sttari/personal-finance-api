# Database connection string used by Prisma.
# Local dev format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/finance_dev

# Port the Express server listens on. Railway sets this automatically in production.
PORT=3000

# Which environment we're running in. Affects logging, error detail, etc.
# Values: development | production | test
NODE_ENV=development

CORS_ORIGIN=http://localhost:3001